RewriteEngine On

RewriteCond %{THE_REQUEST} \s/+index\.php[\s?] [NC]
RewriteRule ^index\.php$ ./ [R=301,L]
RewriteCond %{THE_REQUEST} \s/+jadwal\.php[\s?] [NC]
RewriteRule ^jadwal\.php$ jadwal [R=301,L]
RewriteCond %{THE_REQUEST} \s/+artikel-list\.php[\s?] [NC]
RewriteRule ^artikel-list\.php$ artikel [R=301,L]
RewriteCond %{THE_REQUEST} \s/+kajian-video\.php[\s?] [NC]
RewriteRule ^kajian-video\.php$ video [R=301,L]
RewriteCond %{THE_REQUEST} \s/+laporan\.php[\s?] [NC]
RewriteRule ^laporan\.php$ laporan [R=301,L]
RewriteCond %{THE_REQUEST} \s/+lokasi\.php[\s?] [NC]
RewriteRule ^lokasi\.php$ lokasi [R=301,L]
RewriteCond %{THE_REQUEST} \s/+infaq-page\.php[\s?] [NC]
RewriteRule ^infaq-page\.php$ infaq [R=301,L]
RewriteCond %{THE_REQUEST} \s/+qurban-page\.php[\s?] [NC]
RewriteRule ^qurban-page\.php$ qurban [R=301,L]
RewriteCond %{THE_REQUEST} \s/+dashboard\.php[\s?] [NC]
RewriteRule ^dashboard\.php$ dashboard [R=301,L]
RewriteCond %{THE_REQUEST} \s/+login\.php[\s?] [NC]
RewriteRule ^login\.php$ dashboard/login [R=301,L]
RewriteCond %{THE_REQUEST} \s/+setup-admin\.php[\s?] [NC]
RewriteRule ^setup-admin\.php$ dashboard/setup-admin [R=301,L]
RewriteCond %{THE_REQUEST} \s/+settings\.php[\s?] [NC]
RewriteRule ^settings\.php$ dashboard/settings [R=301,L]
RewriteCond %{THE_REQUEST} \s/+qurban\.php[\s?] [NC]
RewriteRule ^qurban\.php$ dashboard/qurban [R=301,L]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^$ index.php [L,QSA]
RewriteRule ^sitemap\.xml$ sitemap.php [L,QSA]
RewriteRule ^robots\.txt$ robots.php [L,QSA]
RewriteRule ^jadwal/?$ jadwal.php [L,QSA]
RewriteRule ^artikel/?$ artikel-list.php [L,QSA]
RewriteRule ^artikel/([^/]+)/?$ artikel-detail.php?slug=$1 [L,QSA,B]
RewriteRule ^video/?$ kajian-video.php [L,QSA]
RewriteRule ^video/([0-9]+)/?$ video-detail.php?id=$1 [L,QSA,B]
RewriteRule ^laporan/?$ laporan.php [L,QSA]
RewriteRule ^laporan/([^/]+)/?$ laporan-detail.php?slug=$1 [L,QSA,B]
RewriteRule ^lokasi/?$ lokasi.php [L,QSA]
RewriteRule ^infaq/?$ infaq-page.php [L,QSA]
RewriteRule ^qurban/?$ qurban-page.php [L,QSA]

RewriteRule ^dashboard/login/?$ login.php [L,QSA]
RewriteRule ^dashboard/logout/?$ logout.php [L,QSA]
RewriteRule ^dashboard/setup-admin/?$ setup-admin.php [L,QSA]
RewriteRule ^dashboard/?$ dashboard.php [L,QSA]
RewriteRule ^dashboard/kajian/?$ kajian.php [L,QSA]
RewriteRule ^dashboard/artikel/?$ artikel.php [L,QSA]
RewriteRule ^dashboard/gallery/?$ gallery.php [L,QSA]
RewriteRule ^dashboard/video/?$ video.php [L,QSA]
RewriteRule ^dashboard/infaq/?$ infaq.php [L,QSA]
RewriteRule ^dashboard/qurban/?$ qurban.php [L,QSA]
RewriteRule ^dashboard/laporan/?$ laporan-admin.php [L,QSA]
RewriteRule ^dashboard/settings/?$ settings.php [L,QSA]
